{
  "name": "@aws-amplify/backend-notifications",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws-amplify/amplify-backend.git"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "post:compile": "npm run bundle:write-handler && npm run bundle:push-handler && npm run bundle:campaign-association-handler",
    "bundle:write-handler": "esbuild src/lambda/write/handler.ts --bundle --platform=node --target=node20 --format=cjs --outfile=lib/handler-asset/index.js --external:@aws-sdk/*",
    "bundle:push-handler": "esbuild src/lambda/push/handler.ts --bundle --platform=node --target=node20 --format=cjs --outfile=lib/push-handler-asset/index.js --external:@aws-sdk/*",
    "bundle:campaign-association-handler": "esbuild src/lambda/campaign-association/handler.ts --bundle --platform=node --target=node20 --format=cjs --outfile=lib/campaign-association-asset/index.js --external:@aws-sdk/*",
    "update:api": "api-extractor run --local"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-amplify/backend-output-schemas": "^1.8.0",
    "@aws-amplify/platform-core": "^1.11.1",
    "@aws-amplify/plugin-types": "^1.12.1"
  },
  "devDependencies": {
    "@aws-amplify/backend-output-storage": "^1.3.5",
    "@aws-amplify/backend-platform-test-stubs": "^0.3.10",
    "@aws-sdk/client-connect": "^3.1079.0",
    "@aws-sdk/client-connectcampaignsv2": "^3.1079.0",
    "@aws-sdk/client-customer-profiles": "^3.936.0",
    "@aws-sdk/client-dynamodb": "^3.936.0",
    "@aws-sdk/client-iam": "^3.936.0",
    "@aws-sdk/client-pinpoint": "^3.936.0",
    "@aws-sdk/client-qconnect": "^3.1079.0",
    "@types/aws-lambda": "^8.10.137"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.234.1",
    "constructs": "^10.0.0"
  }
}
