{
  "origins": {
    "default": {
      "type": "function",
      "handler": "index.handler",
      "streaming": true,
      "runtime": "nodejs20.x"
    },
    "s3": {
      "type": "s3"
    }
  },
  "behaviors": [
    {
      "pattern": "/_next/static/*",
      "origin": "s3"
    },
    {
      "pattern": "/_next/image",
      "origin": "image-optimization"
    },
    {
      "pattern": "/*",
      "origin": "default"
    }
  ],
  "additionalProps": {
    "disableIncrementalCache": false,
    "imageOptimization": true
  }
}
